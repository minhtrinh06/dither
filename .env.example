# --- Storage (optional) ------------------------------------------------------
# Leave unset to run fully local (IndexedDB mock store, per-device gallery).
# Set both to switch the app to Supabase — see README "Connecting Supabase".
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Moderation (server-side only — NEVER expose these to the client) --------
# Used by the Supabase Edge Function / your server, not by Vite. Examples:
# SIGHTENGINE_API_USER=
# SIGHTENGINE_API_SECRET=
# AWS_ACCESS_KEY_ID= / AWS_SECRET_ACCESS_KEY=   (for Rekognition)
